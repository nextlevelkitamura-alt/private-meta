# Private meta repository allowlist.
#
# This repository tracks only workspace-level governance and shared
# automation metadata. Individual project repositories under this directory
# stay independent and are intentionally ignored by default.

# Ignore every top-level path unless explicitly allowed below.
/*

# Root entry files.
!/.gitignore
!/AGENTS.md
!/CLAUDE.md

# Governance and specs.
!/docs/
!/docs/**

# Personal OS planning layer. Keep the nested AI agent foundation repo independent.
!/personal-os/
/personal-os/*
!/personal-os/AGENTS.md
!/personal-os/CLAUDE.md
!/personal-os/my-brain/
/personal-os/my-brain/*
!/personal-os/my-brain/AGENTS.md
!/personal-os/my-brain/CLAUDE.md
# 縦の目標ladder（3年→年間→デイリー）。areaブロックと違い除外物が無いので全サブツリーを追跡する。
!/personal-os/my-brain/ゴール/
!/personal-os/my-brain/ゴール/**
!/personal-os/my-brain/areas/
/personal-os/my-brain/areas/*
!/personal-os/my-brain/areas/AGENTS.md
!/personal-os/my-brain/areas/CLAUDE.md
!/personal-os/my-brain/areas/現在地.md
# 各areaは下記ブロックを1つ持つ: dir許可 → 中身無視 → AGENTS/CLAUDE/identity + plans/** を許可。
# 新しいareaを足したら同じブロックを追記する。忘れると新規ファイルが静かに無視される。
!/personal-os/my-brain/areas/ai運用/
/personal-os/my-brain/areas/ai運用/*
!/personal-os/my-brain/areas/ai運用/AGENTS.md
!/personal-os/my-brain/areas/ai運用/CLAUDE.md
!/personal-os/my-brain/areas/ai運用/identity.md
!/personal-os/my-brain/areas/ai運用/plans/
!/personal-os/my-brain/areas/ai運用/plans/**
!/personal-os/my-brain/areas/work/
/personal-os/my-brain/areas/work/*
!/personal-os/my-brain/areas/work/AGENTS.md
!/personal-os/my-brain/areas/work/CLAUDE.md
!/personal-os/my-brain/areas/work/identity.md
!/personal-os/my-brain/areas/work/plans/
!/personal-os/my-brain/areas/work/plans/**
!/personal-os/my-brain/areas/money/
/personal-os/my-brain/areas/money/*
!/personal-os/my-brain/areas/money/AGENTS.md
!/personal-os/my-brain/areas/money/CLAUDE.md
!/personal-os/my-brain/areas/money/identity.md
!/personal-os/my-brain/areas/money/plans/
!/personal-os/my-brain/areas/money/plans/**
!/personal-os/my-brain/areas/health/
/personal-os/my-brain/areas/health/*
!/personal-os/my-brain/areas/health/AGENTS.md
!/personal-os/my-brain/areas/health/CLAUDE.md
!/personal-os/my-brain/areas/health/identity.md
!/personal-os/my-brain/areas/health/plans/
!/personal-os/my-brain/areas/health/plans/**

# Project-local global skill bridges.
!/.agents/
!/.agents/**
!/.claude/
!/.claude/skills/
!/.claude/skills/**

# Shared scripts, schemas, and tests.
!/scripts/
!/scripts/**
!/schemas/
!/schemas/**
!/tests/
!/tests/**

# Keep local machine settings and generated artifacts out of the meta repo.
/.claude/*
!/.claude/skills/
!/.claude/skills/**
/.DS_Store
**/.DS_Store
**/__pycache__/
*.py[cod]
