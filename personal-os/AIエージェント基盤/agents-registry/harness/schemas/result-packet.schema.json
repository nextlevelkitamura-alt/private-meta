{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plan result packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task_id", "status", "base_commit", "result_commit", "changed_paths", "tests", "assumptions", "blockers", "remaining_risks", "out_of_scope_findings"],
  "properties": {
    "version": {"const": 1},
    "task_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["done", "blocked", "partial", "failed"]},
    "base_commit": {"type": "string"},
    "result_commit": {"type": "string"},
    "changed_paths": {"type": "array", "items": {"type": "string"}},
    "tests": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["command", "status", "summary"], "properties": {"command": {"type": "string"}, "status": {"enum": ["passed", "failed", "skipped", "not_run"]}, "summary": {"type": "string"}}}},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "remaining_risks": {"type": "array", "items": {"type": "string"}},
    "out_of_scope_findings": {"type": "array", "items": {"type": "string"}}
  }
}
