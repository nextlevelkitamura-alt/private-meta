<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.kitamura.inbox-tick</string>

  <!--
    draft。置くだけ・未ロード（有効化は人間ゲート＝運用契約§2・§7の破壊操作ゲート対象。
    2026-07-09 デイリー運用刷新 子06で新設）。

    60秒ごと（StartInterval 60）に scripts/inbox-tick.sh を呼ぶ。1tick =
      (1) notion-inbox-pull.sh: Notion「立案済」行を当日デイリーへ回収（常時・AIなし）
      (2) patrol.sh: デイリー未処理行のheadless起案
          （state/inbox-patrol-enabled フラグがある時のみ＝第2の人間ゲート）
    遅延はNotion起票からデイリー回収まで最大60秒＋起案まで次tick＝計90秒以内を狙う設計
    （稼働中の daily-notion-sync 30秒tickと同方式）。

    有効化する場合（symlink方式。daily-notion-sync と同じ実運用パターン。手順の正本は loop.md）:
      ln -s '/Users/kitamuranaohiro/Private/personal-os/AIエージェント基盤/loops-registry/loops/inbox-patrol/com.kitamura.inbox-tick.plist' \
        ~/Library/LaunchAgents/com.kitamura.inbox-tick.plist
      launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.kitamura.inbox-tick.plist
      launchctl enable gui/$(id -u)/com.kitamura.inbox-tick
    停止:
      launchctl bootout gui/$(id -u)/com.kitamura.inbox-tick
    手動実行: cd <このフォルダ> && scripts/inbox-tick.sh

    旧 com.kitamura.inbox-patrol.plist（patrol直叩き30分毎）はこのtickに置き換えられる。
    同時にロードしない（patrol.shのmkdirロックで二重処理はしないが、二重駆動を運用に持ち込まない）。
    RunAtLoad は付けない（起動直後の連打を避ける。既存draft plistと同じ方針）。
    patrol.sh は役割別許可設定（settings/inbox-triage-permissions.json）でheadless AIを起動し、
    skip-permissions は使わない（詳細は loop.md「権限」節）。
  -->

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd '/Users/kitamuranaohiro/Private/personal-os/AIエージェント基盤/loops-registry/loops/inbox-patrol' &amp;&amp; scripts/inbox-tick.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/kitamuranaohiro/Private/personal-os/AIエージェント基盤/loops-registry/loops/inbox-patrol</string>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/kitamuranaohiro</string>
    <key>PATH</key>
    <string>/Users/kitamuranaohiro/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>TZ</key>
    <string>Asia/Tokyo</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/kitamuranaohiro/Private/personal-os/AIエージェント基盤/loops-registry/loops/inbox-patrol/output/logs/tick.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/kitamuranaohiro/Private/personal-os/AIエージェント基盤/loops-registry/loops/inbox-patrol/output/logs/tick.err.log</string>
</dict>
</plist>
