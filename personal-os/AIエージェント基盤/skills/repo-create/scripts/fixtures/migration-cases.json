{
  "schema_version": "repo-create.migration-fixtures.v1",
  "contract": "../../references/migration-contract.md",
  "normalization": {
    "fixture_root": "$FIXTURE_ROOT",
    "private_root": "$PRIVATE",
    "repo_root": "$REPO",
    "sort": [
      "path",
      "code",
      "id"
    ],
    "timestamps": "omitted",
    "secret_values": "forbidden"
