{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kitamura.local/schemas/transcript.schema.json",
  "title": "Local Whisper Transcript",
  "type": "object",
  "required": ["source", "engine", "segments", "units", "speech_blocks", "caption_blocks"],
  "properties": {
    "source": {
      "type": "object",
      "required": ["input_path", "audio_path", "duration_sec", "language"],
      "properties": {
        "input_path": { "type": "string" },
        "audio_path": { "type": "string" },
        "duration_sec": { "type": ["number", "null"], "minimum": 0 },
        "language": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "engine": {
      "type": "object",
      "required": ["name", "model", "word_timestamps"],
      "properties": {
        "name": { "const": "mlx-whisper" },
        "model": { "type": "string" },
        "word_timestamps": { "type": "boolean" },
        "condition_on_previous_text": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "start", "end", "raw_text", "unit_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^s[0-9]{6}$" },
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "raw_text": { "type": "string" },
          "unit_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^u[0-9]{6}$" }
          }
        },
        "additionalProperties": true
      }
    },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "segment_id", "start", "end", "text"],
        "properties": {
          "id": { "type": "string", "pattern": "^u[0-9]{6}$" },
          "segment_id": { "type": "string", "pattern": "^s[0-9]{6}$" },
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "text": { "type": "string" },
          "probability": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": true
      }
    },
    "speech_blocks": {
      "type": "array"
    },
    "caption_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "start", "end", "unit_ids", "raw_text", "clean_text", "line_breaks", "duration_sec"],
        "properties": {
          "id": { "type": "string", "pattern": "^c[0-9]{6}$" },
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "unit_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^u[0-9]{6}$" }
          },
          "raw_text": { "type": "string" },
          "clean_text": { "type": "string" },
          "line_breaks": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": { "type": "string" }
          },
          "duration_sec": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
